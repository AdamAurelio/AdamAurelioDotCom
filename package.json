{
  "name": "adamaurelio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Personal website and resume for Adam Aurelio — static React SPA.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "qa:up": "docker compose -f docker-compose.qa.yml up -d --build",
    "qa:down": "docker compose -f docker-compose.qa.yml down",
    "data:up": "cd nas_data_tier && docker compose -f docker-compose.data.yml up -d --build",
    "data:down": "cd nas_data_tier && docker compose -f docker-compose.data.yml down",
    "tf:init": "terraform -chdir=infra/terraform init",
    "tf:plan": "terraform -chdir=infra/terraform plan",
    "tf:apply": "terraform -chdir=infra/terraform apply",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "husky": "^9.1.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.5",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": "eslint --max-warnings 0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
