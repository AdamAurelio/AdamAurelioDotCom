# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/

# Test output
coverage/
playwright-report/
test-results/
/blob-report/
/playwright/.cache/

# Husky internals (generated)
.husky/_/

# Self-update agent single-instance locks (created on the NAS)
.qa-update.lock/
.data-tier-update.lock/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (never commit secrets; commit a *.example instead)
.env
.env.*
!.env.example

# Terraform — never commit state (may contain secrets) or the local provider
# cache. The .terraform.lock.hcl (provider hash pins) IS committed on purpose.
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Misc
*.bak
*.tmp
*.old

# Personal/career documents — local working files, never for the (public) repo
docs/brag_doc*.md
docs/PORTFOLIO_ROADMAP.md
