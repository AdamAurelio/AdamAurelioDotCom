# Copy to .env (gitignored) and set strong, unique values.
# Generate secrets with: openssl rand -base64 32

# Postgres password for the `app` role (used by the API to connect).
POSTGRES_PASSWORD=replace-with-openssl-rand-base64-32

# Shared API key. Remember: NOT secret if sent from the public SPA — see README.
API_KEY=replace-with-openssl-rand-base64-32

# The single browser origin allowed to call the API (your prod site).
# Defaults to https://adamaurelio.com if unset.
ALLOWED_ORIGIN=https://adamaurelio.com
