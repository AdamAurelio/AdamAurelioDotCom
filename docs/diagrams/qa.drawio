<mxfile host="app.diagrams.net" type="device">
  <diagram id="qa-env" name="QA">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="QA environment — Synology NAS (pull-based, ADR-0005: the NAS reaches out; nothing pushes in)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="github" value="GitHub&#10;origin/qa (website)&#10;origin/main (data tier)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="170" height="90" as="geometry" />
        </mxCell>
        <mxCell id="nas" value="Synology NAS — Container Manager (Docker)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="70" width="630" height="500" as="geometry" />
        </mxCell>
        <mxCell id="cron" value="DSM Task Scheduler&#10;(timer, every 5–10 min — change-aware)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="350" y="110" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="qaupdate" value="qa-update.sh&#10;git fetch → rebuild if qa moved" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="350" y="210" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="dataupdate" value="data-tier-update.sh&#10;rebuild only if nas_data_tier/ changed" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="350" y="300" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="web" value="web — Dockerfile build&#10;nginx serves dist/ on :8080&#10;(SPA fallback, security headers, /health)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="660" y="200" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="api" value="api — Node/Express&#10;127.0.0.1:3001 (loopback only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="660" y="320" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pg" value="postgres&#10;no published port (internal Docker net), named volume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="660" y="410" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="proxy" value="DSM reverse proxy :443&#10;Let's Encrypt (DNS-01 via Route 53)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="350" y="410" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="browser" value="Browser (LAN / qa.adamaurelio.com)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="510" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="e_pull" value="git fetch (outbound only — no inbound ports)" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="qaupdate" target="github">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_cron_qa" value="" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="cron" target="qaupdate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_cron_data" value="" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="cron" target="dataupdate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_qa_web" value="up -d --build" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="qaupdate" target="web">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_data_api" value="up -d --build" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="dataupdate" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_api_pg" value="internal net" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="api" target="pg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_browser_proxy" value="https" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="browser" target="proxy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_proxy_web" value="→ :8080" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="proxy" target="web">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_proxy_api" value="→ :3001" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="proxy" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
