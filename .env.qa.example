# QA Environment Configuration (Synology NAS)
# Copy this file to .env.qa and fill in your values

# Django Settings
DJANGO_ENV=qa
DJANGO_SECRET_KEY=your-qa-secret-key-here-make-it-long-and-random
DEBUG=False

# Database Configuration
DB_NAME=adamaurelio_qa
DB_USER=postgres
DB_PASSWORD=your-strong-qa-password-here
DB_HOST=db
DB_PORT=5432

# Synology Configuration
QA_HOST=your-synology-ip-or-hostname

# Frontend Configuration
REACT_APP_API_URL=http://your-synology-ip:8001
REACT_APP_ENV=qa

# Email Configuration (still uses console for QA)
EMAIL_BACKEND=console
