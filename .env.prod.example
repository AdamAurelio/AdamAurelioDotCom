# Production Environment Configuration (AWS Lightsail)
# Copy this file to .env.prod and fill in your values
# IMPORTANT: Keep this file secure and never commit to Git

# Django Settings
DJANGO_ENV=production
DJANGO_SECRET_KEY=your-production-secret-key-use-50-chars-or-more-random-string
DEBUG=False

# Database Configuration
DB_NAME=adamaurelio_prod
DB_USER=postgres
DB_PASSWORD=your-very-strong-production-password
DB_HOST=db
DB_PORT=5432

# AWS Configuration
AWS_HOST=your-lightsail-static-ip

# Domain Configuration
DOMAIN=adamaurelio.com

# Frontend Configuration
REACT_APP_API_URL=https://api.adamaurelio.com
REACT_APP_ENV=production

# Email Configuration (Configure with your email service)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@adamaurelio.com

# Cloudflare Configuration (optional, for API integration)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
